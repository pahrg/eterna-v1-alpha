<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui"
	xmlns:wcag="urn:import:org.roda.wui.common.client.widgets.wcag"
	xmlns:common="urn:import:org.roda.wui.client.common"
	xmlns:redact="urn:import:org.roda.wui.client.redact">

	<ui:with field='messages' type='config.i18n.client.ClientMessages' />

	<wcag:AccessibleFocusPanel ui:field="keyboardFocus">
		<g:FlowPanel styleName="pdf-redactor">
			<common:NavigationToolbar ui:field="navigationToolbar" header="{messages.catalogueFileTitle}" />
			<g:FlowPanel addStyleNames="pdf-redactor-center" ui:field="center">
				<redact:PDFRedactorPanel ui:field="pdfRedactorPanel" />
			</g:FlowPanel>
		</g:FlowPanel>
	</wcag:AccessibleFocusPanel>
</ui:UiBinder>
